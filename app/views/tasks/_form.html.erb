<div id="task_form">
  <%= form_with model: @task, class: "flex gap-2 w-full" do |form| %>
    <div class="flex-1">
      <%= form.text_field :description,
            placeholder: "What needs to be done?",
            maxlength: 200,
            autofocus: true,
            class: [
              "w-full rounded-lg border px-4 py-2.5 text-sm shadow-sm",
              "bg-white dark:bg-gray-800 text-gray-900 dark:text-gray-100",
              "placeholder-gray-400 dark:placeholder-gray-500",
              @task.errors[:description].any? ?
                "border-red-400 dark:border-red-500" :
                "border-gray-300 dark:border-gray-600"
            ] %>
      <% if @task.errors[:description].any? %>
        <p class="mt-1 text-xs text-red-600 dark:text-red-400">
          <%= @task.errors[:description].first %>
        </p>
      <% end %>
    </div>
    <%= form.submit "Add Task",
          class: "flex-shrink-0 rounded-lg px-4 py-2.5 bg-blue-600 hover:bg-blue-700 text-white text-sm font-medium shadow-sm transition-colors cursor-pointer dark:bg-blue-500 dark:hover:bg-blue-600" %>
  <% end %>
</div>
