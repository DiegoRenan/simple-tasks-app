<div class="w-full max-w-2xl mx-auto">
  <header class="mb-8">
    <h1 class="text-3xl font-bold text-gray-900 dark:text-gray-100 mb-1">My Tasks</h1>
    <p class="text-sm text-gray-500 dark:text-gray-400"><%= pluralize(@tasks.count, "task") %> total</p>
  </header>

  <div class="sticky top-16 z-20 bg-gray-50 dark:bg-gray-950 pb-4 mb-2">
    <%= render "form" %>
  </div>

  <div id="tasks" class="bg-white dark:bg-gray-900 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 overflow-hidden">
    <% if @tasks.any? %>
      <%= render @tasks %>
    <% else %>
      <p id="empty_tasks_message" class="text-center py-12 text-gray-400 dark:text-gray-600 text-sm">
        No tasks yet. Add one above!
      </p>
    <% end %>
  </div>
</div>
