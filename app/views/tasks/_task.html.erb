<div id="<%= dom_id(task) %>"
     class="flex items-center justify-between py-3 px-4 border-b border-gray-200 dark:border-gray-700 last:border-b-0">
  <div class="flex items-center gap-3 flex-1 min-w-0">
    <%= button_to toggle_complete_task_path(task), method: :patch, class: "flex-shrink-0 text-lg leading-none bg-transparent border-0 cursor-pointer p-0", form: { "data-turbo-stream": "" } do %>
      <%= task.completed? ? "☑" : "☐" %>
    <% end %>
    <span class="<%= task.completed? ? 'line-through text-gray-400 dark:text-gray-600' : 'text-gray-900 dark:text-gray-100' %> truncate">
      <%= task.description %>
    </span>
  </div>
  <div class="ml-3 flex items-center gap-2 flex-shrink-0">
    <% if task.completed? %>
      <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-200">
        Done
      </span>
    <% end %>
    <%= link_to "Edit", edit_task_path(task), data: { turbo_stream: "" }, class: "text-xs text-blue-500 hover:text-blue-700 dark:text-blue-400 dark:hover:text-blue-300" %>
    <%= button_to "Delete", task_path(task), method: :delete, class: "text-xs text-red-500 hover:text-red-700 dark:text-red-400 dark:hover:text-red-300 bg-transparent border-0 cursor-pointer p-0", form: { "data-turbo-stream": "" } %>
  </div>
</div>
