<div id="<%= dom_id(task) %>"
     class="flex items-center justify-between py-3 px-4 border-b border-gray-200 dark:border-gray-700 last:border-b-0">
  <div class="flex items-center gap-3 flex-1 min-w-0">
    <span class="text-lg flex-shrink-0"><%= task.completed? ? "☑" : "☐" %></span>
    <span class="<%= task.completed? ? 'line-through text-gray-400 dark:text-gray-600' : 'text-gray-900 dark:text-gray-100' %> truncate">
      <%= task.description %>
    </span>
  </div>
  <% if task.completed? %>
    <span class="ml-3 flex-shrink-0 inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-200">
      Done
    </span>
  <% end %>
</div>
