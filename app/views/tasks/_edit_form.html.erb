<div id="<%= dom_id(task) %>"
     class="flex items-center justify-between py-3 px-4 border-b border-gray-200 dark:border-gray-700 last:border-b-0">
  <%= form_with model: task, class: "flex gap-2 w-full" do |form| %>
    <div class="flex-1">
      <%= form.text_field :description,
            maxlength: 200,
            autofocus: true,
            class: [
              "w-full rounded-lg border px-4 py-2 text-sm shadow-sm",
              "bg-white dark:bg-gray-800 text-gray-900 dark:text-gray-100",
              "border-gray-300 dark:border-gray-600",
              task.errors[:description].any? ? "border-red-400 dark:border-red-500" : ""
            ] %>
      <% if task.errors[:description].any? %>
        <p class="mt-1 text-xs text-red-600 dark:text-red-400">
          <%= task.errors[:description].first %>
        </p>
      <% end %>
    </div>
    <%= form.submit "Save", class: "flex-shrink-0 rounded-lg px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white text-sm font-medium shadow-sm transition-colors cursor-pointer dark:bg-blue-500 dark:hover:bg-blue-600" %>
    <%= link_to "Cancel", task_path(task), data: { turbo_stream: "" }, class: "flex-shrink-0 rounded-lg px-4 py-2 bg-gray-200 hover:bg-gray-300 text-gray-700 text-sm font-medium transition-colors dark:bg-gray-700 dark:hover:bg-gray-600 dark:text-gray-200" %>
  <% end %>
</div>
