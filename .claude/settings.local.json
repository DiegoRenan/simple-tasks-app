{
  "permissions": {
    "allow": [
      "Bash(bin/rails db:migrate *)",
      "Bash(bin/rails test *)",
      "Bash(bundle exec *)"
    ],
    "deny": [
      "Bash(curl *)",
      "Bash(**/.env)",
      "Bash(**/.env.*)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Write(**/.env)",
      "Write(**/.env.*)"
    ]
  },
  "enabledPlugins": {
    "ruby-lsp@claude-plugins-official": true
  }
}
